---
import Wordmark from './Wordmark.astro';
import PalmMotif from './PalmMotif.astro';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
interface Props { lang?: Lang; }
const { lang = 'ar' } = Astro.props;
const t = useTranslations(lang);
const cols = [
  { h: t('foot.col.discover'), links: [t('foot.l.historic'), t('foot.l.nature'), t('foot.l.crafts'), t('foot.l.taste')] },
  { h: t('foot.col.plan'), links: [t('foot.l.stay'), t('foot.l.getThere'), t('foot.l.routes'), t('foot.l.events')] },
  { h: t('foot.col.site'), links: [t('foot.l.about'), t('foot.l.brand'), t('foot.l.privacy'), t('foot.l.contact')] },
];
const year = new Date().getFullYear();
---
<footer class="site-footer on-dark">
  <div class="container ft-grid">
    <div class="ft-brand">
      <Wordmark variant="sand" size="md" />
      <p class="ft-tag">{t('foot.tagline')}</p>
      <PalmMotif size={48} class="ft-palm" />
    </div>
    {cols.map((c) => (
      <nav class="ft-col" aria-label={c.h}>
        <h3 class="ft-h">{c.h}</h3>
        <ul>{c.links.map((l) => <li><a href="#">{l}</a></li>)}</ul>
      </nav>
    ))}
  </div>
  <div class="container ft-bar">
    <span>© {year} {t('site.name')} — {t('foot.rights')}</span>
    <a href="mailto:info@visit-alahsa.com" class="ft-mail">info@visit-alahsa.com</a>
  </div>
</footer>

<style>
  .site-footer { background: var(--c-turq-deep); color: var(--c-sand); padding-block: var(--s-8) var(--s-5); margin-block-start: var(--s-8); }
  .ft-grid { display: grid; grid-template-columns: 1.6fr repeat(3, 1fr); gap: var(--s-6); }
  .ft-tag { color: rgba(247,243,234,.7); margin-block-start: var(--s-3); max-inline-size: 34ch; font-size: var(--t-sm); }
  :global(.ft-palm) { color: var(--c-gold); opacity: .55; margin-block-start: var(--s-4); }
  .ft-h { font-size: var(--t-lg); color: var(--c-sand); margin-block-end: var(--s-3); }
  .ft-col ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--s-2); }
  .ft-col a { color: rgba(247,243,234,.74); text-decoration: none; font-size: var(--t-sm); transition: color var(--dur) var(--ease); }
  .ft-col a:hover { color: var(--c-gold); }
  .ft-bar { display: flex; justify-content: space-between; align-items: center; gap: var(--s-3); margin-block-start: var(--s-7); padding-block-start: var(--s-4); border-block-start: 1px solid rgba(247,243,234,.14); font-size: var(--t-sm); color: rgba(247,243,234,.62); flex-wrap: wrap; }
  .ft-mail { font-family: var(--font-latin); letter-spacing: .04em; color: var(--c-gold); text-decoration: none; }
  @media (max-width: 760px) { .ft-grid { grid-template-columns: 1fr 1fr; } .ft-brand { grid-column: 1 / -1; } }
</style>
